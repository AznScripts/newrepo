if not game:IsLoaded() then game.Loaded:Wait() end
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/AznScripts/newrepo/refs/heads/main/uilib"))()
local antiafk = loadstring(game:HttpGet("https://raw.githubusercontent.com/AznScripts/newrepo/refs/heads/main/antiafk"))()

local w = Library:Window("Fishu")
local t = Library:Window("Teleport")

if getgenv().FishLoop then
    getgenv().FishLoop:Disconnect()
end

local Players = cloneref(game:GetService("Players"))
local ReplicatedStorage = cloneref(game:GetService("ReplicatedStorage"))
local RunService = cloneref(game:GetService("RunService"))
local player = Players.LocalPlayer
local mainGui = player.PlayerGui.MainGui
local bubble = mainGui.Fishing.Bubble
local hotbar = mainGui.Main.Hotbar.List
local areaFolder = workspace:WaitForChild("Area")
local DataPath = ReplicatedStorage.Data[player.UserId]
local farmpos

getgenv().AutoFish = false
getgenv().JesusMode = false
getgenv().AutoSell = false
getgenv().FiredBubbles = getgenv().FiredBubbles or {}

local fired = getgenv().FiredBubbles
local lastFishing = 0
local lastHotbar = 0

local ignore = {
	["Atom's Something Fishing Store"] = true,
	["Retro World: Ocean"] = true,
	["The Dream"] = true,
}

getgenv().FishLoop = RunService.Heartbeat:Connect(function()
if not getgenv().AutoFish then
     return
end

local limitObj = mainGui.Inventory.MainMenu.Inventory.Upper:FindFirstChild("Limit")
if limitObj then
local current, max = limitObj.Text:match("([^/]+)/([^/]+)")
    if current == max then
       return
   end
end

if tick() - lastHotbar >= 2 then
    local rods = {}

    for _, rod in ipairs(DataPath.FishingRodInventory:GetChildren()) do
        rods[rod.Name] = true
    end

    for _, v in ipairs(hotbar:GetChildren()) do
        if v:IsA("TextButton") then
            local title = v:FindFirstChild("Title")

            if title
            and title:IsA("TextLabel")
            and rods[title.Text]
            and v.Select.ImageTransparency ~= 0 then

                lastHotbar = tick()
                ReplicatedStorage.Events.ToggleHotbar:InvokeServer(v.Name)
                break
            end
        end
    end
end

if mainGui.Main.Visible and tick() - lastFishing >= 3 then
      lastFishing = tick()
      ReplicatedStorage.Events.Fishing:FireServer()
end

for _, child in ipairs(bubble:GetChildren()) do
      if child:IsA("CanvasGroup")
      and child.Name ~= "Template"
      and not fired[child] then

          fired[child] = true

          ReplicatedStorage.Events.BubbleHandler:FireServer(
              child.Name,
                nil,
                {Position = child.Position})
            child.Destroying:Once(function()
                fired[child] = nil
            end)
        end
    end
end)

task.spawn(function()
    while task.wait() do
        for _, v in ipairs(workspace.Water:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = getgenv().JesusMode
            end
        end
    end
end)


task.spawn(function()
    while task.wait() do
        if getgenv().AutoSell then

            local gamepass = DataPath.Gamepass:FindFirstChild("1683659694")
            local limitObj = mainGui.Inventory.MainMenu.Inventory.Upper:FindFirstChild("Limit")

            if limitObj then
                local text = limitObj.Text
                local current, max = text:match("([^/]+)/([^/]+)")

                if current == max then
                    if gamepass and gamepass.Value == true then
                        ReplicatedStorage.Events.SellFish:InvokeServer("All")
                    else
                        local npcFolder = workspace.NPC:FindFirstChild("Fish Vendor")
                        if npcFolder then
                            local vendorModel = npcFolder:FindFirstChildWhichIsA("Model")
                            if vendorModel then
                                if not vendorModel.PrimaryPart then
                                    vendorModel.PrimaryPart = vendorModel:FindFirstChildWhichIsA("BasePart")
                                end
                                if vendorModel.PrimaryPart then
                                    player.Character:PivotTo(vendorModel.PrimaryPart.CFrame)
                                    task.wait(0.2)
                                    ReplicatedStorage.Events.SellFish:InvokeServer("All")
				   if farmpos then 
				       task.wait(0.2)
				       player.Character:PivotTo(farmpos)
                                    end
				end
                            end
                        end
                    end
                end
            end
        end
    end
end)

w:Toggle("Auto Fish", function(v)
    getgenv().AutoFish = v
end)

w:Toggle("Jesus Mode", function(v)
    getgenv().JesusMode = v
end)

w:Button("Set Farm Position", function()
    farmpos = player.Character.HumanoidRootPart.CFrame
end)

w:Toggle("Sell When Max", function(v)
    getgenv().AutoSell = v
end)

w:TextLabel("Inventory", function()
   return
   mainGui.Inventory.MainMenu.Inventory.Upper.Limit.Text
end)

w:TextLabel("Cash", function()
   return
   mainGui.Main.Stats.Cash.Value.Text
end)

for _, area in ipairs(areaFolder:GetChildren()) do
	if not ignore[area.Name] then
		t:Button(area.Name, function()
			player.Character.HumanoidRootPart.CFrame = area.CFrame
		end)
	end
end
