local UiLib = Instance.new("ScreenGui")
UiLib.Name = "UiLib"
UiLib.ResetOnSpawn = false
UiLib.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
UiLib.IgnoreGuiInset = true
UiLib.Parent = GuiParent

local function getNextWindowPos()
	local biggest = 0
	local ok = nil

	for _, v in pairs(UiLib:GetChildren()) do
		if v:IsA("Frame") and v.Name == "Top" then
			if v.Position.X.Offset > biggest then
				biggest = v.Position.X.Offset
				ok = v
			end
		end
	end

	if biggest == 0 then
		biggest += 15
	else
		biggest += ok.Size.X.Offset + 10
	end

	return biggest
end

