local vu = game:GetService("VirtualUser")
local lp = game:GetService("Players").LocalPlayer
local coregui = game:GetService("CoreGui")

if getconnections then
    for _, connection in pairs(getconnections(lp.Idled)) do
        if connection["Disconnect"] then
            connection["Disconnect"](connection)
        end
    end
end

lp.Idled:Connect(function()
    vu:CaptureController()
    vu:ClickButton2(Vector2.new())
end)
local function removePause()
    local gui = coregui:FindFirstChild("RobloxGui")
    if gui then
        local pause = gui:FindFirstChild("CoreScripts/NetworkPause")
        if pause then
            pause:Destroy()
        end
    end
end

removePause()

coregui.RobloxGui.ChildAdded:Connect(function(obj)
    if obj.Name == "CoreScripts/NetworkPause" then
        obj:Destroy()
    end
end)
